# Copie para deploy.env na raiz ResunaWeb e preencha (deploy.env está no .gitignore).
# Usado por deploy.sh para injetar NEXT_PUBLIC_* no build do frontend na Cloud Build.
#
# Valores: consola Firebase → Definições do projeto → As tuas aplicações → SDK snippet.
# Turnstile: Cloudflare Dashboard → Turnstile → site key (pública).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Opcional: se vazio, o widget Turnstile não aparece no UI (backend pode ainda exigir token se Turnstile estiver on).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
