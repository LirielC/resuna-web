rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // hasValidUserId: garante que o campo userId no documento bate com o UID do usuário autenticado.
    function hasValidUserId() {
      return request.resource.data.userId == request.auth.uid;
    }

    // userIdNotChanged: impede que atualizações alterem o dono do documento.
    // Fix: removida a primeira condição `!('userId' in ...)` que era dead-code em updates e
    // permitia que um set() sem o campo userId passasse a validação.
    function userIdNotChanged() {
      return request.resource.data.userId == resource.data.userId;
    }

    // ===== RESUMES =====
    // Arquitetura local-first: currículos vivem no localStorage do navegador, NÃO no Firestore.
    // O backend usa Admin SDK (ignora estas regras). Nenhum cliente deve ler/escrever aqui diretamente.

    match /resumes/{resumeId} {
      allow read, write: if false;
    }

    // ===== COVER LETTERS =====
    // Mesma decisão arquitetural: cartas de apresentação ficam no localStorage.
    // Escrita e leitura client-side bloqueadas; Admin SDK do backend não é afetado.

    match /coverLetters/{letterId} {
      allow read, write: if false;
    }

    // ===== ATS ANALYSES =====
    // ATENÇÃO: os dados ficam na SUBcoleção users/{userId}/ats_analyses/ (ver bloco USERS abaixo).
    // A regra raiz /ats_analyses foi removida por ser letra morta (nenhum dado é escrito aqui).

    // ===== USERS =====

    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && hasValidUserId();
      allow update: if isOwner(userId) && userIdNotChanged();
      allow delete: if isOwner(userId);

      match /ats_analyses/{analysisId} {
        allow read:  if isOwner(userId);
        allow write: if false;
      }
    }

    // ===== USER SUBSCRIPTIONS =====
    // Escrita apenas pelo backend (Admin SDK).
    // Nota: user_subscriptions e subscriptions são duas coleções com a mesma regra.
    // Verifique qual o backend realmente usa e remova a redundante futuramente.

    match /user_subscriptions/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    match /subscriptions/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // ===== USER PROFILES =====

    match /user_profiles/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // ===== FEATURE FLAGS =====

    match /feature_flags/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // ===== BILLING EVENTS =====

    match /billing_events/{eventId} {
      allow read:  if isAdmin() ||
                      (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    // ===== USER ACTIVITIES (admin only) =====

    match /user_activities/{activityId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ===== USAGE AGGREGATES (admin only) =====

    match /usage_aggregates/{aggregateId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ===== INITIAL CREDITS COUNTERS (server only) =====

    match /initial_credits_counters/{counterId} {
      allow read, write: if false;
    }

    // ===== AUDIT LOGS (admin only) =====
    // Fix: removido o acesso self-read. Logs de auditoria são sensíveis — permitir que o
    // próprio usuário leia seus logs revelaria quais ações estão sendo monitoradas,
    // facilitando evasão de detecção. Consistente com user_activities e usage_aggregates.

    match /audit_logs/{logId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ===== DENY ALL (default) =====
    // Qualquer coleção não listada acima é bloqueada por padrão.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
